# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/

# Virtual environments
.venv/
venv/
env/

# Environment variables — never commit
.env

# Remote-server runtime artifacts — contain the secret URL, or are noise
CONNECTOR_URL.txt
scratch_*.log
scratch_*.txt

# Uploaded user documents — commit only the placeholders
inputs/*
!inputs/.gitkeep

# Shared reference uploads
references/*
!references/.gitkeep

# macOS
.DS_Store

# IDE
.idea/
.vscode/
